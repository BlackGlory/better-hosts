    "husky": "4",
    "npm-run-all": "^4.1.5",
    "return-style": "^4.0.0",
    "rimraf": "^6.1.3",
    "standard-version": "^9.5.0",
    "ts-patch": "^3.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "typescript-transform-paths": "^3.5.6",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "yarn-deduplicate": "^6.0.2"
  },
